{
  "enabled": true,
  "name": "Sync Docs on Source Change",
  "description": "Watches Python source files, config, and requirements for changes. When a change is detected, asks the agent to update the README (or /docs folder if present) to reflect the latest code.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.py",
      "requirements.txt",
      ".env.example"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A source file was just modified. Review the change and update the README.md to reflect any relevant updates — such as new features, changed configuration, new tools, updated usage instructions, or new dependencies. If a /docs folder exists, update the relevant files there too. Keep the documentation accurate and concise."
  }
}